# =============================================================================
# 3Sixty Docker Compose .gitignore
# =============================================================================

# Environment files with secrets
.env
.env.*
!.env.sample
*.env
!sample.env.*

# SSL/TLS Certificates and Keys
nginx/certs/*.key
nginx/certs/*.crt
nginx/certs/*.pem
nginx/certs/*.p12
nginx/certs/*.pfx
*.key
*.crt
*.pem

# Logs
logs/
*.log
*.log.*

# Backup files
backups/
*.backup
*.bak
*.dump
*.archive

# Vault token files
vault-agent/.vault-token
.vault-token
*.vault-token

# Docker volumes and data
volumes/
data/

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Claude AI project files
.claude/
.aider*
.cursor/

# Temporary files
tmp/
temp/
*.tmp

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Node modules (if any local tooling)
node_modules/

# Python virtual environments (if any)
venv/
env/
.venv/
__pycache__/
*.pyc

# Terraform state (if using Terraform)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Kubernetes secrets (if any)
*-secret.yaml
*-secrets.yaml

# Database dumps and exports
*.sql
*.dump
*.csv

# Monitoring data
prometheus_data/
grafana_data/

# Build artifacts
dist/
build/
*.tar.gz
*.zip

# Development overrides
docker-compose.override.yml
docker-compose.local.yml

# macOS
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# Allow certain files explicitly
# =============================================================================
!.gitignore
!.gitkeep
