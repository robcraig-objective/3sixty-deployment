# =============================================================================
# 3Sixty Environment Configuration
# =============================================================================
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env to version control
#
# Quick setup:
#   1. cp .env.sample .env
#   2. Update all CHANGEME values below
#   3. Configure Azure AD settings (CLIENT_ID, TENANT_ID, CLIENT_SECRET)
#   4. Run: make start
# =============================================================================

# -----------------------------------------------------------------------------
# Global Settings
# -----------------------------------------------------------------------------
TZ=Australia/Sydney
GLOBAL_ORG=objective

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGO_INITDB_DATABASE=threesixty
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGEME_STRONG_PASSWORD_HERE

# MongoDB connection string (used by applications)
MONGODB_NAME=${MONGO_INITDB_DATABASE}
MONGODB_USERNAME=${MONGO_INITDB_ROOT_USERNAME}
MONGODB_PASSWORD=${MONGO_INITDB_ROOT_PASSWORD}
MONGODB_URI=mongodb://${MONGODB_USERNAME}:${MONGODB_PASSWORD}@mongo:27017/${MONGODB_NAME}

# -----------------------------------------------------------------------------
# RabbitMQ Configuration
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=CHANGEME_RABBITMQ_PASSWORD
RABBITMQ_QUEUE=scim-queue

# Used by services connecting to RabbitMQ
RABBITMQ_USERNAME=${RABBITMQ_DEFAULT_USER}
RABBITMQ_PASSWORD=${RABBITMQ_DEFAULT_PASS}

# -----------------------------------------------------------------------------
# Azure AD / OAuth2 Configuration
# -----------------------------------------------------------------------------
# Required for Discovery service authentication
# Get these from Azure Portal > App Registrations
CLIENT_ID=CHANGEME_YOUR_AZURE_APP_CLIENT_ID
TENANT_ID=CHANGEME_YOUR_AZURE_TENANT_ID
CLIENT_SECRET=CHANGEME_YOUR_AZURE_APP_SECRET

# OAuth2 configuration
OAUTH2_ENABLED=true

# -----------------------------------------------------------------------------
# 3Sixty Admin Service
# -----------------------------------------------------------------------------
SSL_ENABLED=false
APP_URI=http://threesixty-admin:8080/3sixty-admin

# -----------------------------------------------------------------------------
# SCIM Server Configuration
# -----------------------------------------------------------------------------
SCIM_TOKEN_URL=http://scim-server:8083/scim/v2/token
SCIM_USERNAME=scim-application-admin
SCIM_PASSWORD=CHANGEME_SCIM_PASSWORD

# gRPC Configuration
GRPC_SERVER_START=true
GRPC_SERVER_SSL=false

# -----------------------------------------------------------------------------
# OI RAG Configuration
# -----------------------------------------------------------------------------
# RAG service settings
OIRAG_LOG_LEVEL=INFO
OIRAG_EMBEDDING_MODEL=mxbai-embed-large
OIRAG_OLLAMA_URL=http://ollama:11434

# -----------------------------------------------------------------------------
# Remote Agent Configuration (Optional)
# -----------------------------------------------------------------------------
# Configure after creating remote agent in Admin UI
# Leave blank until agent is created
REMOTE_AGENT_NAME=
REMOTE_AGENT_TOKEN=
REMOTE_AGENT_ENDPOINT=http://threesixty-admin:8080/3sixty-admin

# -----------------------------------------------------------------------------
# Vault Configuration (Optional - Dev Mode)
# -----------------------------------------------------------------------------
# WARNING: Only for development! Use production mode for real deployments
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VAULT_DEV_ROOT_TOKEN_ID=root

# -----------------------------------------------------------------------------
# Monitoring Configuration (Optional)
# -----------------------------------------------------------------------------
# Prometheus
PROMETHEUS_RETENTION=15d

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGEME_GRAFANA_PASSWORD

# -----------------------------------------------------------------------------
# Security Notes
# -----------------------------------------------------------------------------
# 1. Generate strong passwords using: openssl rand -base64 32
# 2. Never use default passwords in production
# 3. Rotate credentials regularly (90 days recommended)
# 4. Use HashiCorp Vault for production secret management
# 5. Enable RBAC for all services
# 6. Use Azure Key Vault for cloud deployments
#
# Password Requirements:
# - Minimum 16 characters
# - Mix of uppercase, lowercase, numbers, symbols
# - No dictionary words
# - Unique per service
# =============================================================================
