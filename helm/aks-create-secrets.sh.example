#!/usr/bin/env bash
# ============================================================================
# aks-create-secrets.sh
# ============================================================================
# Creates Kubernetes secrets for 3Sixty deployment using Azure CLI commands.
# Uses 'az aks command invoke' — does NOT require direct kubectl access to the
# cluster network. Works on Linux, macOS, and Windows (Git Bash).
#
# Prerequisites:
#   az       — Azure CLI (logged in via 'az login')
#   aws      — AWS CLI (for ECR image pull credentials)
#   openssl  — for TLS certificate generation
#   jq       — for parsing az aks command invoke JSON responses
#
# Usage:
#   chmod +x aks-create-secrets.sh
#   ./aks-create-secrets.sh --resource-group <rg> --cluster-name <cluster>
#   — or —
#   make secrets-aks AKS_RG=<rg> AKS_CLUSTER=<cluster>
#
# ============================================================================
# CONFIGURATION HIERARCHY
# ============================================================================
# These two variables must match the corresponding Makefile variables:
#
#   NAMESPACE    ↔  Makefile: NAMESPACE   (default: threesixty)
#   RELEASE_NAME ↔  Makefile: RELEASE     (default: threesixty-stack)
#
# RELEASE_NAME also determines Kubernetes service names used in connection
# URIs and environment variables. For example, RABBITMQ_HOST in
# values-production.yaml must equal "${RELEASE_NAME}-rabbitmq".
#
# If you change RELEASE or NAMESPACE in the Makefile, update them here too.
#
# NOTE ON SPECIAL CHARACTERS:
# Unlike kubectl-create-secrets.sh which passes credentials directly via
# --from-literal flags, this script base64-encodes YAML manifests and applies
# them through 'az aks command invoke'. This avoids shell-escaping issues with
# special characters ($, !, #, @) in passwords when transmitted as strings
# through the AKS command invoke API. Secret names and keys are IDENTICAL
# between both scripts — only the creation mechanism differs.
# ============================================================================
set -euo pipefail

# ============================================================================
# Argument parsing
# ============================================================================
usage() {
    echo "Usage: $0 --resource-group <rg> --cluster-name <cluster> [--namespace <ns>]"
    echo ""
    echo "Options:"
    echo "  --resource-group, -g   Azure resource group containing the AKS cluster"
    echo "  --cluster-name,   -c   AKS cluster name"
    echo "  --namespace,      -n   Kubernetes namespace (default: threesixty)"
    exit 1
}

RESOURCE_GROUP=""
CLUSTER_NAME=""
NAMESPACE="threesixty"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --resource-group|-g) RESOURCE_GROUP="$2"; shift 2 ;;
        --cluster-name|-c)   CLUSTER_NAME="$2";   shift 2 ;;
        --namespace|-n)      NAMESPACE="$2";       shift 2 ;;
        *) usage ;;
    esac
done

[[ -z "$RESOURCE_GROUP" || -z "$CLUSTER_NAME" ]] && usage

# ============================================================================
# Configuration — keep in sync with Makefile RELEASE and NAMESPACE variables
# ============================================================================
RELEASE_NAME="threesixty-stack"   # Must match: make install RELEASE=...

ECR_SERVER="782396859527.dkr.ecr.ap-southeast-2.amazonaws.com"
ECR_REGION="ap-southeast-2"
DOMAIN="threesixty.objective.com"

# ============================================================================
# Credential Variables — SET THESE BEFORE RUNNING
# ============================================================================
MONGO_ROOT_USERNAME=""
MONGO_ROOT_PASSWORD=""

RABBITMQ_USER=""
RABBITMQ_PASS=""

OPENSEARCH_PASSWORD=""
OIRAG_BEARER_TOKEN=""

REMOTE_AGENT_TOKEN=""
SSL_CA_PASSWORD=""

# OAuth2 Configuration (Azure AD / Entra ID)
OAUTH2_CLIENT_ID=""
OAUTH2_TENANT_ID=""
OAUTH2_CLIENT_SECRET=""
OAUTH2_SCOPES="openid,profile,email,offline_access"

# SCIM Server credentials
SCIM_USERNAME=""
SCIM_PASSWORD=""

# MongoDB database names
MONGO_DATABASE="simflofy"
MONGO_SCIM_DATABASE="scim-database"

# ============================================================================
# Colour helpers
# ============================================================================
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
RESET='\033[0m'

step()  { echo -e "\n${CYAN}[STEP] $*${RESET}"; }
ok()    { echo -e "${GREEN}[OK] $*${RESET}"; }
warn()  { echo -e "${YELLOW}[WARN] $*${RESET}"; }
err()   { echo -e "${RED}[ERROR] $*${RESET}"; }

# ============================================================================
# Helper: base64-encode a string value (portable — strips newlines)
# ============================================================================
b64() { printf '%s' "$1" | base64 | tr -d '\n'; }

# ============================================================================
# Helper: run a command inside the AKS cluster via az aks command invoke
# ============================================================================
invoke_aks() {
    local description="$1"
    local command="$2"
    local allow_fail="${3:-false}"

    echo -e "  ${CYAN}→${RESET} $description"
    local result exit_code logs
    result=$(az aks command invoke \
        --resource-group "$RESOURCE_GROUP" \
        --name "$CLUSTER_NAME" \
        --command "$command" \
        --output json 2>&1)

    if [[ $? -ne 0 ]]; then
        if [[ "$allow_fail" == "true" ]]; then
            warn "$description (skipped — Azure API error)"
            return 0
        fi
        err "Azure CLI error for: $description"
        echo "$result"
        exit 1
    fi

    exit_code=$(echo "$result" | jq -r '.exitCode // 0')
    logs=$(echo "$result" | jq -r '.logs // ""')

    if [[ "$exit_code" != "0" ]]; then
        if echo "$logs" | grep -q "already exists"; then
            ok "$description (already exists)"
            return 0
        fi
        if [[ "$allow_fail" == "true" ]]; then
            warn "$description (non-fatal failure)"
            return 0
        fi
        err "Command failed: $description"
        echo "$logs"
        exit 1
    fi

    ok "$description"
    [[ -n "$logs" ]] && echo -e "${RESET}$logs"
    return 0
}

# ============================================================================
# Helper: base64-encode a YAML manifest and apply it via AKS command invoke
# ============================================================================
apply_secret_yaml() {
    local description="$1"
    local yaml="$2"
    local yaml_b64
    yaml_b64=$(printf '%s' "$yaml" | base64 | tr -d '\n')
    invoke_aks "$description" "echo $yaml_b64 | base64 -d | kubectl apply -f -"
}

# ============================================================================
# Pre-flight checks
# ============================================================================
echo -e "\n${CYAN}========================================${RESET}"
echo -e "${CYAN}3Sixty Kubernetes Secrets Setup (Azure CLI)${RESET}"
echo -e "${CYAN}========================================${RESET}\n"
echo -e "  Resource Group : ${CYAN}${RESOURCE_GROUP}${RESET}"
echo -e "  Cluster Name   : ${CYAN}${CLUSTER_NAME}${RESET}"
echo -e "  Namespace      : ${CYAN}${NAMESPACE}${RESET}"
echo ""

step "Checking prerequisites..."
for tool in az aws openssl jq; do
    if ! command -v "$tool" &>/dev/null; then
        err "$tool not found. Run 'make check-prerequisites' for install instructions."
        exit 1
    fi
    ok "$tool found"
done

step "Checking Azure authentication..."
ACCOUNT=$(az account show 2>/dev/null) || { err "Not logged into Azure. Run: az login"; exit 1; }
ok "Logged in as $(echo "$ACCOUNT" | jq -r '.user.name')"

step "Verifying AKS cluster exists..."
CLUSTER=$(az aks show --resource-group "$RESOURCE_GROUP" --name "$CLUSTER_NAME" 2>/dev/null) \
    || { err "AKS cluster '$CLUSTER_NAME' not found in resource group '$RESOURCE_GROUP'"; exit 1; }
ok "AKS cluster found: $(echo "$CLUSTER" | jq -r '.name') (Kubernetes $(echo "$CLUSTER" | jq -r '.kubernetesVersion'))"

# ============================================================================
# Validate credential variables
# ============================================================================
step "Validating credential variables..."
MISSING=()
[[ -z "$MONGO_ROOT_USERNAME"  ]] && MISSING+=("MONGO_ROOT_USERNAME")
[[ -z "$MONGO_ROOT_PASSWORD"  ]] && MISSING+=("MONGO_ROOT_PASSWORD")
[[ -z "$RABBITMQ_USER"        ]] && MISSING+=("RABBITMQ_USER")
[[ -z "$RABBITMQ_PASS"        ]] && MISSING+=("RABBITMQ_PASS")
[[ -z "$OPENSEARCH_PASSWORD"  ]] && MISSING+=("OPENSEARCH_PASSWORD")
[[ -z "$OIRAG_BEARER_TOKEN"   ]] && MISSING+=("OIRAG_BEARER_TOKEN")
[[ -z "$REMOTE_AGENT_TOKEN"   ]] && MISSING+=("REMOTE_AGENT_TOKEN")
[[ -z "$SSL_CA_PASSWORD"      ]] && MISSING+=("SSL_CA_PASSWORD")
[[ -z "$OAUTH2_CLIENT_ID"     ]] && MISSING+=("OAUTH2_CLIENT_ID")
[[ -z "$OAUTH2_TENANT_ID"     ]] && MISSING+=("OAUTH2_TENANT_ID")
[[ -z "$OAUTH2_CLIENT_SECRET" ]] && MISSING+=("OAUTH2_CLIENT_SECRET")
[[ -z "$SCIM_USERNAME"        ]] && MISSING+=("SCIM_USERNAME")
[[ -z "$SCIM_PASSWORD"        ]] && MISSING+=("SCIM_PASSWORD")

if [[ ${#MISSING[@]} -gt 0 ]]; then
    err "The following credential variables are empty. Set them at the top of this script:"
    for var in "${MISSING[@]}"; do echo "  $var"; done
    exit 1
fi
ok "All credential variables set"

# ============================================================================
# Create namespace
# ============================================================================
step "Creating namespace '$NAMESPACE'..."
invoke_aks "Create namespace" "kubectl create namespace $NAMESPACE" "true"
invoke_aks "Verify namespace exists" "kubectl get namespace $NAMESPACE"

# ============================================================================
# ECR registry secret
# ============================================================================
step "Creating ECR registry secret..."
ECR_PASSWORD=$(aws ecr get-login-password --region "$ECR_REGION") \
    || { err "Failed to get ECR password. Check AWS CLI credentials."; exit 1; }
ok "ECR password retrieved"

ECR_ESCAPED="${ECR_PASSWORD//\"/\\\"}"
invoke_aks "Delete existing ECR secret" \
    "kubectl delete secret ecr-registry-secret -n $NAMESPACE --ignore-not-found=true" "true"
invoke_aks "Create ECR registry secret" \
    "kubectl create secret docker-registry ecr-registry-secret --docker-server=${ECR_SERVER} --docker-username=AWS --docker-password=${ECR_ESCAPED} -n ${NAMESPACE}"

# ============================================================================
# TLS certificate secret
# ============================================================================
# Certs are generated locally then applied via base64-encoded YAML.
# az aks command invoke cannot transfer binary files directly.
step "Creating TLS certificate for domain '$DOMAIN'..."
mkdir -p certs
openssl req -x509 -newkey rsa:2048 -days 365 \
    -nodes \
    -keyout certs/tls.key \
    -out  certs/tls.crt \
    -subj "/CN=$DOMAIN" 2>/dev/null
ok "Certificate generated: certs/tls.crt"
ok "Private key generated: certs/tls.key"

CERT_B64=$(base64 < certs/tls.crt | tr -d '\n')
KEY_B64=$(base64 < certs/tls.key | tr -d '\n')

TLS_YAML="apiVersion: v1
kind: Secret
type: kubernetes.io/tls
metadata:
  name: traefik-tls
  namespace: $NAMESPACE
data:
  tls.crt: $CERT_B64
  tls.key: $KEY_B64"

invoke_aks "Delete existing TLS secret" \
    "kubectl delete secret traefik-tls -n $NAMESPACE --ignore-not-found=true" "true"
apply_secret_yaml "Create TLS secret" "$TLS_YAML"

# ============================================================================
# RabbitMQ secret
# ============================================================================
step "Creating RabbitMQ secret..."
RABBIT_SECRET="${RELEASE_NAME}-rabbitmq-secret"
apply_secret_yaml "Create RabbitMQ secret ($RABBIT_SECRET)" \
"apiVersion: v1
kind: Secret
metadata:
  name: $RABBIT_SECRET
  namespace: $NAMESPACE
type: Opaque
data:
  RABBITMQ_DEFAULT_USER: $(b64 "$RABBITMQ_USER")
  RABBITMQ_DEFAULT_PASS: $(b64 "$RABBITMQ_PASS")"

# ============================================================================
# MongoDB init secret
# ============================================================================
step "Creating MongoDB init secret..."
MONGO_SECRET="${RELEASE_NAME}-mongo-init-secret"
apply_secret_yaml "Create MongoDB init secret ($MONGO_SECRET)" \
"apiVersion: v1
kind: Secret
metadata:
  name: $MONGO_SECRET
  namespace: $NAMESPACE
type: Opaque
data:
  MONGO_INITDB_ROOT_USERNAME: $(b64 "$MONGO_ROOT_USERNAME")
  MONGO_INITDB_ROOT_PASSWORD: $(b64 "$MONGO_ROOT_PASSWORD")"

# ============================================================================
# OpenSearch admin secret
# ============================================================================
step "Creating OpenSearch admin secret..."
OS_SECRET="${RELEASE_NAME}-opensearch-admin-secret"
apply_secret_yaml "Create OpenSearch admin secret ($OS_SECRET)" \
"apiVersion: v1
kind: Secret
metadata:
  name: $OS_SECRET
  namespace: $NAMESPACE
type: Opaque
data:
  OPENSEARCH_INITIAL_ADMIN_PASSWORD: $(b64 "$OPENSEARCH_PASSWORD")"

# ============================================================================
# OI-RAG secret
# ============================================================================
step "Creating OI-RAG secret..."
OIRAG_SECRET="${RELEASE_NAME}-hybridsearch-oirag-secret"
apply_secret_yaml "Create OI-RAG secret ($OIRAG_SECRET)" \
"apiVersion: v1
kind: Secret
metadata:
  name: $OIRAG_SECRET
  namespace: $NAMESPACE
type: Opaque
data:
  OPENSEARCH_PASSWORD: $(b64 "$OPENSEARCH_PASSWORD")
  BEARER_TOKEN: $(b64 "$OIRAG_BEARER_TOKEN")"

# ============================================================================
# Remote Agent secret
# ============================================================================
step "Creating Remote Agent secret..."
RA_SECRET="${RELEASE_NAME}-hybridsearch-remoteagent-secret"
apply_secret_yaml "Create Remote Agent secret ($RA_SECRET)" \
"apiVersion: v1
kind: Secret
metadata:
  name: $RA_SECRET
  namespace: $NAMESPACE
type: Opaque
data:
  REMOTE_AGENT_TOKEN: $(b64 "$REMOTE_AGENT_TOKEN")
  SSL_CA_PASSWORD: $(b64 "$SSL_CA_PASSWORD")"

# ============================================================================
# Admin secret
# ============================================================================
step "Creating Admin secret..."
MONGO_HOST="${RELEASE_NAME}-mongo"
MONGODB_URI="mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@${MONGO_HOST}:27017/${MONGO_DATABASE}?authSource=admin"
ADMIN_SECRET="${RELEASE_NAME}-admin-secret"
apply_secret_yaml "Create Admin secret ($ADMIN_SECRET)" \
"apiVersion: v1
kind: Secret
metadata:
  name: $ADMIN_SECRET
  namespace: $NAMESPACE
type: Opaque
data:
  MONGODB_URI: $(b64 "$MONGODB_URI")
  RABBITMQ_USERNAME: $(b64 "$RABBITMQ_USER")
  RABBITMQ_PASSWORD: $(b64 "$RABBITMQ_PASS")
  SCIM_USERNAME: $(b64 "$SCIM_USERNAME")
  SCIM_PASSWORD: $(b64 "$SCIM_PASSWORD")"

# ============================================================================
# SCIM secret
# ============================================================================
step "Creating SCIM secret..."
SCIM_MONGO_URI="mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@${MONGO_HOST}:27017/${MONGO_SCIM_DATABASE}?authSource=admin"
SCIM_SECRET="${RELEASE_NAME}-scim-secret"
apply_secret_yaml "Create SCIM secret ($SCIM_SECRET)" \
"apiVersion: v1
kind: Secret
metadata:
  name: $SCIM_SECRET
  namespace: $NAMESPACE
type: Opaque
data:
  SCIM_USERNAME: $(b64 "$SCIM_USERNAME")
  SCIM_PASSWORD: $(b64 "$SCIM_PASSWORD")
  SCIM_STORAGE_MONGO_CONSTR: $(b64 "$SCIM_MONGO_URI")
  SCIM_STORAGE_MONGO_DATABASE: $(b64 "$MONGO_SCIM_DATABASE")"

# ============================================================================
# OAuth2 secret
# ============================================================================
step "Creating OAuth2 secret..."
OAUTH2_SECRET="${RELEASE_NAME}-oauth2-secret"
apply_secret_yaml "Create OAuth2 secret ($OAUTH2_SECRET)" \
"apiVersion: v1
kind: Secret
metadata:
  name: $OAUTH2_SECRET
  namespace: $NAMESPACE
type: Opaque
data:
  CLIENT_ID: $(b64 "$OAUTH2_CLIENT_ID")
  TENANT_ID: $(b64 "$OAUTH2_TENANT_ID")
  CLIENT_SECRET: $(b64 "$OAUTH2_CLIENT_SECRET")
  SCOPES: $(b64 "$OAUTH2_SCOPES")"

# ============================================================================
# Verify
# ============================================================================
step "Verifying created secrets..."
invoke_aks "List secrets in namespace" "kubectl get secrets -n $NAMESPACE"

echo -e "\n${GREEN}========================================${RESET}"
echo -e "${GREEN}[OK] All secrets created successfully!${RESET}"
echo -e "${GREEN}========================================${RESET}\n"
echo "Next steps:"
echo "  1. make deps"
echo "  2. make install"
echo ""
echo -e "${YELLOW}Note: The TLS certificate is self-signed (for development).${RESET}"
echo "For production, replace with a CA-signed certificate."
