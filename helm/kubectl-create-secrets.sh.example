#!/usr/bin/env bash
# ============================================================================
# kubectl-create-secrets.sh
# ============================================================================
# Creates Kubernetes secrets for 3Sixty deployment using kubectl commands.
# Works on Linux, macOS, and Windows (Git Bash).
#
# Prerequisites:
#   kubectl  — configured for your target cluster
#   aws      — AWS CLI (for ECR image pull credentials)
#   openssl  — for TLS certificate generation
#
# Usage:
#   chmod +x kubectl-create-secrets.sh
#   ./kubectl-create-secrets.sh
#   — or —
#   make secrets-kubectl
#
# ============================================================================
# CONFIGURATION HIERARCHY
# ============================================================================
# These two variables must match the corresponding Makefile variables:
#
#   NAMESPACE    ↔  Makefile: NAMESPACE   (default: threesixty)
#   RELEASE_NAME ↔  Makefile: RELEASE     (default: threesixty-stack)
#
# RELEASE_NAME also determines Kubernetes service names used in connection
# URIs and environment variables. For example, RABBITMQ_HOST in
# values-production.yaml must equal "${RELEASE_NAME}-rabbitmq".
#
# If you change RELEASE or NAMESPACE in the Makefile, update them here too.
# ============================================================================
set -euo pipefail

# ============================================================================
# Configuration — keep in sync with Makefile RELEASE and NAMESPACE variables
# ============================================================================
NAMESPACE="threesixty"
RELEASE_NAME="threesixty-stack"   # Must match: make install RELEASE=...

ECR_SERVER="782396859527.dkr.ecr.ap-southeast-2.amazonaws.com"
ECR_REGION="ap-southeast-2"
DOMAIN="threesixty.objective.com"

# ============================================================================
# Credential Variables — SET THESE BEFORE RUNNING
# ============================================================================
MONGO_ROOT_USERNAME="dbuser"
MONGO_ROOT_PASSWORD="mongopassword"

RABBITMQ_USER="rabbituser"
RABBITMQ_PASS="rabbitpassword"

OPENSEARCH_PASSWORD="OpenSearch1!"
OIRAG_BEARER_TOKEN="trial-oirag-bearer-token"

REMOTE_AGENT_TOKEN="trial-remote-agent-token"
SSL_CA_PASSWORD="trial-ssl-ca-password"

# OAuth2 Configuration (Azure AD / Entra ID)
# Get these from: Azure Portal → App registrations → your app
OAUTH2_CLIENT_ID=""
OAUTH2_TENANT_ID=""
OAUTH2_CLIENT_SECRET=""
OAUTH2_SCOPES="openid,profile,email,offline_access"

# SCIM Server credentials
SCIM_USERNAME="scimadmin"
SCIM_PASSWORD="scimpassword"

# MongoDB database names (used to build connection URIs)
# Host is derived automatically as ${RELEASE_NAME}-mongo
# Change only if using an external MongoDB instance
MONGO_DATABASE="simflofy"
MONGO_SCIM_DATABASE="scim-database"

# ============================================================================
# Colour helpers
# ============================================================================
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
RESET='\033[0m'

step()  { echo -e "\n${CYAN}[STEP] $*${RESET}"; }
ok()    { echo -e "${GREEN}[OK] $*${RESET}"; }
warn()  { echo -e "${YELLOW}[WARN] $*${RESET}"; }
err()   { echo -e "${RED}[ERROR] $*${RESET}"; }

# ============================================================================
# Pre-flight checks
# ============================================================================
echo -e "\n${CYAN}========================================${RESET}"
echo -e "${CYAN}3Sixty Kubernetes Secrets Setup (kubectl)${RESET}"
echo -e "${CYAN}========================================${RESET}\n"

step "Checking prerequisites..."

if ! command -v kubectl &>/dev/null; then
    err "kubectl not found. Run 'make check-prerequisites' for install instructions."
    exit 1
fi
ok "kubectl found"

if ! command -v aws &>/dev/null; then
    err "AWS CLI not found. Run 'make check-prerequisites' for install instructions."
    exit 1
fi
ok "AWS CLI found"

OPENSSL_AVAILABLE=false
if ! command -v openssl &>/dev/null; then
    warn "OpenSSL not found — traefik-tls secret will be skipped."
    warn "Install OpenSSL then re-run to create the TLS secret."
else
    ok "OpenSSL found"
    OPENSSL_AVAILABLE=true
fi

step "Checking kubectl connectivity..."
if ! kubectl cluster-info &>/dev/null; then
    err "Cannot connect to Kubernetes cluster."
    err "Run: kubectl config use-context <context-name>"
    err "  or: make aks-credentials AKS_RG=<rg> AKS_CLUSTER=<cluster>"
    exit 1
fi
ok "kubectl connected to cluster"

# ============================================================================
# Validate credential variables
# ============================================================================
step "Validating credential variables..."
MISSING=()
[[ -z "$MONGO_ROOT_USERNAME"  ]] && MISSING+=("MONGO_ROOT_USERNAME")
[[ -z "$MONGO_ROOT_PASSWORD"  ]] && MISSING+=("MONGO_ROOT_PASSWORD")
[[ -z "$RABBITMQ_USER"        ]] && MISSING+=("RABBITMQ_USER")
[[ -z "$RABBITMQ_PASS"        ]] && MISSING+=("RABBITMQ_PASS")
[[ -z "$OPENSEARCH_PASSWORD"  ]] && MISSING+=("OPENSEARCH_PASSWORD")
[[ -z "$OIRAG_BEARER_TOKEN"   ]] && MISSING+=("OIRAG_BEARER_TOKEN")
[[ -z "$REMOTE_AGENT_TOKEN"   ]] && MISSING+=("REMOTE_AGENT_TOKEN")
[[ -z "$SSL_CA_PASSWORD"      ]] && MISSING+=("SSL_CA_PASSWORD")
[[ -z "$OAUTH2_CLIENT_ID"     ]] && MISSING+=("OAUTH2_CLIENT_ID")
[[ -z "$OAUTH2_TENANT_ID"     ]] && MISSING+=("OAUTH2_TENANT_ID")
[[ -z "$OAUTH2_CLIENT_SECRET" ]] && MISSING+=("OAUTH2_CLIENT_SECRET")
[[ -z "$SCIM_USERNAME"        ]] && MISSING+=("SCIM_USERNAME")
[[ -z "$SCIM_PASSWORD"        ]] && MISSING+=("SCIM_PASSWORD")

if [[ ${#MISSING[@]} -gt 0 ]]; then
    err "The following credential variables are empty. Set them at the top of this script:"
    for var in "${MISSING[@]}"; do echo "  $var"; done
    exit 1
fi
ok "All credential variables set"

# ============================================================================
# Create namespace
# ============================================================================
step "Creating namespace '$NAMESPACE'..."
if kubectl get namespace "$NAMESPACE" &>/dev/null; then
    ok "Namespace '$NAMESPACE' already exists"
else
    kubectl create namespace "$NAMESPACE"
    ok "Namespace '$NAMESPACE' created"
fi

# ============================================================================
# ECR registry secret
# ============================================================================
step "Creating ECR registry secret..."
ECR_PASSWORD=""
ECR_PASSWORD=$(aws ecr get-login-password --region "$ECR_REGION" 2>/dev/null) || true
if [[ -n "$ECR_PASSWORD" ]]; then
    ok "ECR password retrieved"
    kubectl delete secret ecr-registry-secret -n "$NAMESPACE" --ignore-not-found=true
    kubectl create secret docker-registry ecr-registry-secret \
        --docker-server="$ECR_SERVER" \
        --docker-username=AWS \
        --docker-password="$ECR_PASSWORD" \
        -n "$NAMESPACE"
    ok "ECR registry secret created"
else
    warn "Failed to get ECR password — skipping ecr-registry-secret."
    warn "Re-run this script (or 'make ecr-login') once AWS credentials are configured."
fi

# ============================================================================
# TLS certificate secret
# ============================================================================
step "Creating TLS certificate for domain '$DOMAIN'..."
if [[ "$OPENSSL_AVAILABLE" == "true" ]]; then
    mkdir -p certs
    openssl req -x509 -newkey rsa:2048 -days 365 \
        -nodes \
        -keyout certs/tls.key \
        -out  certs/tls.crt \
        -subj "/CN=$DOMAIN" 2>/dev/null
    ok "Certificate generated: certs/tls.crt"
    ok "Private key generated: certs/tls.key"

    kubectl delete secret traefik-tls -n "$NAMESPACE" --ignore-not-found=true
    kubectl create secret tls traefik-tls \
        --cert=certs/tls.crt \
        --key=certs/tls.key \
        -n "$NAMESPACE"
    ok "TLS secret created"
else
    warn "[SKIP] traefik-tls — OpenSSL not available."
fi

# ============================================================================
# RabbitMQ secret
# ============================================================================
step "Creating RabbitMQ secret..."
RABBIT_SECRET="${RELEASE_NAME}-rabbitmq-secret"
kubectl delete secret "$RABBIT_SECRET" -n "$NAMESPACE" --ignore-not-found=true
kubectl create secret generic "$RABBIT_SECRET" \
    --from-literal=RABBITMQ_DEFAULT_USER="$RABBITMQ_USER" \
    --from-literal=RABBITMQ_DEFAULT_PASS="$RABBITMQ_PASS" \
    -n "$NAMESPACE"
ok "RabbitMQ secret created ($RABBIT_SECRET)"

# ============================================================================
# MongoDB init secret
# ============================================================================
step "Creating MongoDB init secret..."
MONGO_SECRET="${RELEASE_NAME}-mongo-init-secret"
kubectl delete secret "$MONGO_SECRET" -n "$NAMESPACE" --ignore-not-found=true
kubectl create secret generic "$MONGO_SECRET" \
    --from-literal=MONGO_INITDB_ROOT_USERNAME="$MONGO_ROOT_USERNAME" \
    --from-literal=MONGO_INITDB_ROOT_PASSWORD="$MONGO_ROOT_PASSWORD" \
    -n "$NAMESPACE"
ok "MongoDB init secret created ($MONGO_SECRET)"

# ============================================================================
# OpenSearch admin secret
# ============================================================================
# OPENSEARCH_INITIAL_ADMIN_PASSWORD sets the 'admin' superuser password.
# This MUST match OPENSEARCH_PASSWORD in the OI-RAG secret below.
# Username 'admin' is used in the 3Sixty admin UI when configuring data sources.
step "Creating OpenSearch admin secret..."
OS_SECRET="${RELEASE_NAME}-opensearch-admin-secret"
kubectl delete secret "$OS_SECRET" -n "$NAMESPACE" --ignore-not-found=true
kubectl create secret generic "$OS_SECRET" \
    --from-literal=OPENSEARCH_INITIAL_ADMIN_PASSWORD="$OPENSEARCH_PASSWORD" \
    -n "$NAMESPACE"
ok "OpenSearch admin secret created ($OS_SECRET)"

# ============================================================================
# OI-RAG secret
# ============================================================================
step "Creating OI-RAG secret..."
OIRAG_SECRET="${RELEASE_NAME}-hybridsearch-oirag-secret"
kubectl delete secret "$OIRAG_SECRET" -n "$NAMESPACE" --ignore-not-found=true
kubectl create secret generic "$OIRAG_SECRET" \
    --from-literal=OPENSEARCH_PASSWORD="$OPENSEARCH_PASSWORD" \
    --from-literal=BEARER_TOKEN="$OIRAG_BEARER_TOKEN" \
    -n "$NAMESPACE"
ok "OI-RAG secret created ($OIRAG_SECRET)"

# ============================================================================
# Remote Agent secret
# ============================================================================
step "Creating Remote Agent secret..."
RA_SECRET="${RELEASE_NAME}-hybridsearch-remoteagent-secret"
kubectl delete secret "$RA_SECRET" -n "$NAMESPACE" --ignore-not-found=true
kubectl create secret generic "$RA_SECRET" \
    --from-literal=REMOTE_AGENT_TOKEN="$REMOTE_AGENT_TOKEN" \
    --from-literal=SSL_CA_PASSWORD="$SSL_CA_PASSWORD" \
    -n "$NAMESPACE"
ok "Remote Agent secret created ($RA_SECRET)"

# ============================================================================
# Admin secret
# ============================================================================
# Contains the MongoDB URI, RabbitMQ credentials, and SCIM credentials used
# by the 3Sixty Admin service. Building the URI here keeps credentials out of
# Helm values files and the etcd release manifest.
step "Creating Admin secret..."
MONGO_HOST="${RELEASE_NAME}-mongo"
MONGODB_URI="mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@${MONGO_HOST}:27017/${MONGO_DATABASE}?authSource=admin"
ADMIN_SECRET="${RELEASE_NAME}-admin-secret"
kubectl delete secret "$ADMIN_SECRET" -n "$NAMESPACE" --ignore-not-found=true
kubectl create secret generic "$ADMIN_SECRET" \
    --from-literal=MONGODB_URI="$MONGODB_URI" \
    --from-literal=RABBITMQ_USERNAME="$RABBITMQ_USER" \
    --from-literal=RABBITMQ_PASSWORD="$RABBITMQ_PASS" \
    --from-literal=SCIM_USERNAME="$SCIM_USERNAME" \
    --from-literal=SCIM_PASSWORD="$SCIM_PASSWORD" \
    -n "$NAMESPACE"
ok "Admin secret created ($ADMIN_SECRET)"

# ============================================================================
# SCIM secret
# ============================================================================
step "Creating SCIM secret..."
SCIM_MONGO_URI="mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@${MONGO_HOST}:27017/${MONGO_SCIM_DATABASE}?authSource=admin"
SCIM_SECRET="${RELEASE_NAME}-scim-secret"
kubectl delete secret "$SCIM_SECRET" -n "$NAMESPACE" --ignore-not-found=true
kubectl create secret generic "$SCIM_SECRET" \
    --from-literal=SCIM_USERNAME="$SCIM_USERNAME" \
    --from-literal=SCIM_PASSWORD="$SCIM_PASSWORD" \
    --from-literal=SCIM_STORAGE_MONGO_CONSTR="$SCIM_MONGO_URI" \
    --from-literal=SCIM_STORAGE_MONGO_DATABASE="$MONGO_SCIM_DATABASE" \
    -n "$NAMESPACE"
ok "SCIM secret created ($SCIM_SECRET)"

# ============================================================================
# OAuth2 secret
# ============================================================================
# The Discovery service reads CLIENT_ID, TENANT_ID, CLIENT_SECRET, SCOPES
# directly from this secret via envFrom.secretRef.
step "Creating OAuth2 secret..."
OAUTH2_SECRET="${RELEASE_NAME}-oauth2-secret"
kubectl delete secret "$OAUTH2_SECRET" -n "$NAMESPACE" --ignore-not-found=true
kubectl create secret generic "$OAUTH2_SECRET" \
    --from-literal=CLIENT_ID="$OAUTH2_CLIENT_ID" \
    --from-literal=TENANT_ID="$OAUTH2_TENANT_ID" \
    --from-literal=CLIENT_SECRET="$OAUTH2_CLIENT_SECRET" \
    --from-literal=SCOPES="$OAUTH2_SCOPES" \
    -n "$NAMESPACE"
ok "OAuth2 secret created ($OAUTH2_SECRET)"

# ============================================================================
# Verify
# ============================================================================
step "Verifying all secrets..."
kubectl get secrets -n "$NAMESPACE"

echo -e "\n${GREEN}========================================${RESET}"
echo -e "${GREEN}[OK] All secrets created successfully!${RESET}"
echo -e "${GREEN}========================================${RESET}\n"
echo "Next steps:"
echo "  1. make deps"
echo "  2. make install"
echo ""
echo -e "${YELLOW}Note: The TLS certificate is self-signed (for development).${RESET}"
echo "For production, replace with a CA-signed certificate:"
echo "  kubectl create secret tls traefik-tls \\"
echo "    --cert=/path/to/cert.crt --key=/path/to/cert.key -n $NAMESPACE"
