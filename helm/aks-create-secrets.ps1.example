#!/usr/bin/env pwsh
# ============================================================================
# aks-create-secrets.ps1
# ============================================================================
# Creates Kubernetes secrets for 3Sixty deployment using Azure CLI commands
# This method uses 'az aks command invoke' and doesn't require direct kubectl access
# 
# Prerequisites:
# - Azure CLI installed and authenticated (az login)
# - Contributor or higher permissions on the AKS cluster
# - AWS CLI configured (for ECR access)
# - OpenSSL installed (for certificate generation)
# 
# Usage:
#   .\aks-create-secrets.ps1 -ResourceGroup "my-rg" -ClusterName "my-aks-cluster"
# ============================================================================

param(
    [Parameter(Mandatory=$true)]
    [string]$ResourceGroup,
    
    [Parameter(Mandatory=$true)]
    [string]$ClusterName,
    
    [Parameter(Mandatory=$false)]
    [string]$Namespace = "threesixty"
)

# Configuration from values-production.yaml
$ECR_SERVER  = "782396859527.dkr.ecr.ap-southeast-2.amazonaws.com"
$ECR_REGION  = "ap-southeast-2"
$DOMAIN      = "threesixty.objective.com"
$RELEASE_NAME = "threesixty-stack"  # Must match your helm install release name

# ============================================================================
# Credential Variables - SET THESE BEFORE RUNNING
# ============================================================================
# NOTE: Unlike kubectl-create-secrets.ps1 which expands variables directly,
# this script embeds credentials into base64-encoded YAML manifests and
# applies them via 'az aks command invoke'. This avoids shell-escaping issues
# with special characters ($, !, #, @) when passing --from-literal through
# the AKS command invoke API. The two scripts use identical secret names and
# keys — only the creation mechanism differs.
# ============================================================================
$MONGO_ROOT_USERNAME    = ""   # MongoDB root username (match threesixty.mongodb.username in values)
$MONGO_ROOT_PASSWORD    = ""   # MongoDB root password (match threesixty.mongodb.password in values)

$RABBITMQ_USER          = ""   # RabbitMQ username (match threesixty.rabbitmq.username in values)
$RABBITMQ_PASS          = ""   # RabbitMQ password (match threesixty.rabbitmq.password in values)

$OPENSEARCH_PASSWORD    = ""   # OpenSearch admin password
$OIRAG_BEARER_TOKEN     = ""   # OI-RAG bearer token

$REMOTE_AGENT_TOKEN     = ""   # Remote agent authentication token
$SSL_CA_PASSWORD        = ""   # SSL CA keystore password

# OAuth2 Configuration (Azure AD / Entra ID)
# IMPORTANT: Replace these with your actual Azure AD application values
$OAUTH2_CLIENT_ID       = ""   # Get from Azure Portal > App Registrations
$OAUTH2_TENANT_ID       = ""   # Your Azure AD Tenant ID (found in Azure Portal)
$OAUTH2_CLIENT_SECRET   = ""   # Get from Azure Portal > App Registrations > Certificates & Secrets
$OAUTH2_SCOPES          = "openid,profile,email,offline_access"   # Adjust based on your Azure AD app configuration

# SCIM Server credentials
$SCIM_USERNAME          = ""   # SCIM server username (e.g. "scim-application-admin")
$SCIM_PASSWORD          = ""   # SCIM server password

# MongoDB connection details (used to build connection URIs for admin and SCIM secrets)
# Host is derived automatically as $RELEASE_NAME-mongo — change only if using an external MongoDB
$MONGO_DATABASE         = "simflofy"       # Main application database
$MONGO_SCIM_DATABASE    = "scim-database"  # SCIM server database

# Colors for output
$SuccessColor = "Green"
$ErrorColor = "Red"
$InfoColor = "Cyan"

# ============================================================================
# Helper Functions
# ============================================================================

function Write-Step {
    param([string]$Message)
    Write-Host "`n[STEP] $Message" -ForegroundColor $InfoColor
}

function Write-Success {
    param([string]$Message)
    Write-Host "[OK] $Message" -ForegroundColor $SuccessColor
}

function Write-Error-Message {
    param([string]$Message)
    Write-Host "[ERROR] $Message" -ForegroundColor $ErrorColor
}

function Invoke-AksCommand {
    param(
        [string]$Command,
        [string]$Description
    )
    
    Write-Host "Running: $Description" -ForegroundColor $InfoColor
    $result = az aks command invoke `
        --resource-group $ResourceGroup `
        --name $ClusterName `
        --command $Command `
        --output json 2>&1
    
    if ($LASTEXITCODE -ne 0) {
        Write-Error-Message "Command failed: $Description"
        Write-Host $result -ForegroundColor $ErrorColor
        return $false
    }
    
    # Parse JSON response
    try {
        $resultObj = $result | ConvertFrom-Json
        if ($resultObj.exitCode -ne 0) {
            Write-Host $resultObj.logs -ForegroundColor Yellow
            # Some commands fail if resource already exists - check the message
            if ($resultObj.logs -like "*already exists*") {
                Write-Success "$Description (already exists)"
                return $true
            }
            Write-Error-Message "Command returned non-zero exit code"
            return $false
        }
        Write-Success $Description
        if ($resultObj.logs) {
            Write-Host $resultObj.logs -ForegroundColor Gray
        }
        return $true
    } catch {
        Write-Error-Message "Failed to parse response"
        Write-Host $result -ForegroundColor $ErrorColor
        return $false
    }
}

# ============================================================================
# Pre-flight Checks
# ============================================================================

Write-Host "`n========================================" -ForegroundColor $InfoColor
Write-Host "3Sixty Kubernetes Secrets Setup (Azure CLI)" -ForegroundColor $InfoColor
Write-Host "========================================`n" -ForegroundColor $InfoColor

Write-Host "Target AKS Cluster:" -ForegroundColor $InfoColor
Write-Host "  Resource Group: $ResourceGroup" -ForegroundColor White
Write-Host "  Cluster Name:   $ClusterName" -ForegroundColor White
Write-Host "  Namespace:      $Namespace" -ForegroundColor White
Write-Host ""

Write-Step "Checking prerequisites..."

# Check Azure CLI
if (-not (Get-Command az -ErrorAction SilentlyContinue)) {
    Write-Error-Message "Azure CLI not found. Please install Azure CLI first."
    exit 1
}
Write-Success "Azure CLI found"

# Check AWS CLI
if (-not (Get-Command aws -ErrorAction SilentlyContinue)) {
    Write-Error-Message "AWS CLI not found. Please install AWS CLI for ECR access."
    exit 1
}
Write-Success "AWS CLI found"

# Check OpenSSL
if (-not (Get-Command openssl -ErrorAction SilentlyContinue)) {
    Write-Error-Message "OpenSSL not found. Please install OpenSSL for certificate generation."
    exit 1
}
Write-Success "OpenSSL found"

# Check Azure login
Write-Step "Checking Azure authentication..."
$account = az account show 2>$null | ConvertFrom-Json
if ($LASTEXITCODE -ne 0) {
    Write-Error-Message "Not logged into Azure. Please run: az login"
    exit 1
}
Write-Success "Logged into Azure as $($account.user.name)"

# Check AKS cluster exists
Write-Step "Verifying AKS cluster exists..."
$cluster = az aks show --resource-group $ResourceGroup --name $ClusterName 2>$null | ConvertFrom-Json
if ($LASTEXITCODE -ne 0) {
    Write-Error-Message "AKS cluster not found: $ClusterName in resource group $ResourceGroup"
    exit 1
}
Write-Success "AKS cluster found: $($cluster.name) (Kubernetes $($cluster.kubernetesVersion))"

# ============================================================================
# Create Namespace
# ============================================================================

Write-Step "Creating namespace '$Namespace'..."
$result = Invoke-AksCommand `
    -Command "kubectl create namespace $Namespace" `
    -Description "Create namespace"

if (-not $result) {
    # Check if namespace already exists
    $checkNs = Invoke-AksCommand `
        -Command "kubectl get namespace $Namespace" `
        -Description "Check namespace exists"
    
    if (-not $checkNs) {
        Write-Error-Message "Failed to create or verify namespace"
        exit 1
    }
}

# ============================================================================
# Create ECR Registry Secret
# ============================================================================

Write-Step "Creating ECR registry secret..."

# Get ECR password
Write-Host "Getting ECR login password..." -ForegroundColor $InfoColor
try {
    $ECR_PASSWORD = aws ecr get-login-password --region $ECR_REGION
    if (-not $ECR_PASSWORD) {
        throw "Empty password returned"
    }
    Write-Success "ECR password retrieved"
} catch {
    Write-Error-Message "Failed to get ECR password. Ensure AWS CLI is configured with valid credentials."
    exit 1
}

# Delete existing secret if it exists
Write-Host "Checking for existing ECR secret..." -ForegroundColor $InfoColor
Invoke-AksCommand `
    -Command "kubectl delete secret ecr-registry-secret -n $Namespace --ignore-not-found=true" `
    -Description "Delete existing ECR secret" | Out-Null

# Create new secret
# Note: We need to escape special characters in the password for shell execution
$escapedPassword = $ECR_PASSWORD -replace '"', '\"' -replace '\$', '\$'

$createSecretCmd = "kubectl create secret docker-registry ecr-registry-secret " +
    "--docker-server=$ECR_SERVER " +
    "--docker-username=AWS " +
    "--docker-password=$escapedPassword " +
    "-n $Namespace"

$result = Invoke-AksCommand `
    -Command $createSecretCmd `
    -Description "Create ECR registry secret"

if (-not $result) {
    Write-Error-Message "Failed to create ECR registry secret"
    exit 1
}

# ============================================================================
# Create TLS Certificate Secret
# ============================================================================

Write-Step "Creating TLS certificate for domain '$DOMAIN'..."

# Create certs directory if it doesn't exist
$certsDir = "certs"
if (-not (Test-Path $certsDir)) {
    New-Item -ItemType Directory -Path $certsDir | Out-Null
    Write-Success "Created certs directory"
}

$certPath = "$certsDir/tls.crt"
$keyPath = "$certsDir/tls.key"

# Generate self-signed certificate
Write-Host "Generating self-signed certificate (valid for 365 days)..." -ForegroundColor $InfoColor
openssl req -x509 -newkey rsa:2048 -days 365 `
    -nodes `
    -keyout $keyPath `
    -out $certPath `
    -subj "/CN=$DOMAIN" 2>$null

if ($LASTEXITCODE -eq 0) {
    Write-Success "Certificate generated: $certPath"
    Write-Success "Private key generated: $keyPath"
} else {
    Write-Error-Message "Failed to generate certificate"
    exit 1
}

# Read certificate and key files
$certContent = Get-Content $certPath -Raw
$keyContent = Get-Content $keyPath -Raw

# Base64 encode for transmission
$certBase64 = [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes($certContent))
$keyBase64 = [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes($keyContent))

# Delete existing TLS secret if it exists
Write-Host "Checking for existing TLS secret..." -ForegroundColor $InfoColor
Invoke-AksCommand `
    -Command "kubectl delete secret traefik-tls -n $Namespace --ignore-not-found=true" `
    -Description "Delete existing TLS secret" | Out-Null

# Create TLS secret using YAML approach (more reliable than command-line arguments)
$tlsSecretYaml = @"
apiVersion: v1
kind: Secret
type: kubernetes.io/tls
metadata:
  name: traefik-tls
  namespace: $Namespace
data:
  tls.crt: $certBase64
  tls.key: $keyBase64
"@

# Save YAML to secure temporary file — contains TLS private key material.
# Written to $env:TEMP (not the working directory) and wrapped in try/finally
# so the file is always deleted even if the script errors or is interrupted.
$tempYamlPath = Join-Path $env:TEMP "tls-secret-$(New-Guid).yaml"
try {
    $tlsSecretYaml | Out-File -FilePath $tempYamlPath -Encoding utf8

Write-Host ""
Write-Host "========================================" -ForegroundColor Yellow
Write-Host "TLS Secret Creation - Manual Step Required" -ForegroundColor Yellow
Write-Host "========================================" -ForegroundColor Yellow
Write-Host ""
Write-Host "Due to limitations with 'az aks command invoke' for binary files," -ForegroundColor Yellow
Write-Host "the TLS secret must be created using kubectl directly." -ForegroundColor Yellow
Write-Host ""

Write-Host "Method 1 (Recommended for AKS): Use kubectl with AKS credentials" -ForegroundColor Cyan
Write-Host "------------------------------------------------------------" -ForegroundColor Cyan
Write-Host ""
Write-Host "Step 1: Get AKS cluster credentials (configures kubectl context)" -ForegroundColor White
Write-Host "  az aks get-credentials --resource-group $ResourceGroup --name $ClusterName" -ForegroundColor Green
Write-Host ""
Write-Host "Step 2: Create TLS secret from the generated certificate files" -ForegroundColor White
Write-Host "  kubectl create secret tls traefik-tls --cert=$certPath --key=$keyPath -n $Namespace" -ForegroundColor Green
Write-Host ""
Write-Host "Step 3: Verify the secret was created" -ForegroundColor White
Write-Host "  kubectl get secret traefik-tls -n $Namespace" -ForegroundColor Green
Write-Host ""

Write-Host "Alternative Method 2: Apply the generated YAML file" -ForegroundColor Cyan
Write-Host "------------------------------------------------------------" -ForegroundColor Cyan
Write-Host ""
Write-Host "Step 1: Get AKS cluster credentials (if not already configured)" -ForegroundColor White
Write-Host "  az aks get-credentials --resource-group $ResourceGroup --name $ClusterName" -ForegroundColor Green
Write-Host ""
Write-Host "Step 2: Apply the YAML file" -ForegroundColor White
Write-Host "  kubectl apply -f $tempYamlPath" -ForegroundColor Green
Write-Host ""

# ============================================================================
# Validate credential variables are set
# ============================================================================
# NOTE ON AKS vs KUBECTL DIFFERENCES:
# kubectl-create-secrets.ps1 expands PowerShell variables directly into
# --from-literal flags. This script instead base64-encodes a YAML manifest
# and pipes it through 'base64 -d | kubectl apply -f -' inside the cluster.
# This avoids shell-escaping issues with special characters in passwords
# when commands are transmitted as strings via 'az aks command invoke'.
# Secret names and keys are IDENTICAL between both scripts.
# ============================================================================

Write-Step "Validating credential variables..."
$missingVars = @()
if (-not $MONGO_ROOT_USERNAME)  { $missingVars += "MONGO_ROOT_USERNAME" }
if (-not $MONGO_ROOT_PASSWORD)  { $missingVars += "MONGO_ROOT_PASSWORD" }
if (-not $RABBITMQ_USER)        { $missingVars += "RABBITMQ_USER" }
if (-not $RABBITMQ_PASS)        { $missingVars += "RABBITMQ_PASS" }
if (-not $OPENSEARCH_PASSWORD)  { $missingVars += "OPENSEARCH_PASSWORD" }
if (-not $OIRAG_BEARER_TOKEN)   { $missingVars += "OIRAG_BEARER_TOKEN" }
if (-not $REMOTE_AGENT_TOKEN)   { $missingVars += "REMOTE_AGENT_TOKEN" }
if (-not $SSL_CA_PASSWORD)      { $missingVars += "SSL_CA_PASSWORD" }
if (-not $OAUTH2_CLIENT_ID)     { $missingVars += "OAUTH2_CLIENT_ID" }
if (-not $OAUTH2_TENANT_ID)     { $missingVars += "OAUTH2_TENANT_ID" }
if (-not $OAUTH2_CLIENT_SECRET) { $missingVars += "OAUTH2_CLIENT_SECRET" }
if (-not $SCIM_USERNAME)        { $missingVars += "SCIM_USERNAME" }
if (-not $SCIM_PASSWORD)        { $missingVars += "SCIM_PASSWORD" }

if ($missingVars.Count -gt 0) {
    Write-Error-Message "The following credential variables are empty. Set them at the top of this script before running:"
    $missingVars | ForEach-Object { Write-Host "  `$$_" -ForegroundColor Yellow }
    exit 1
}
Write-Success "All credential variables set"

# Helper: base64-encode a YAML string and apply it to the cluster via AKS command invoke
function Invoke-ApplySecretYaml {
    param(
        [string]$Yaml,
        [string]$Description
    )
    $yamlBase64 = [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes($Yaml))
    $cmd = "echo $yamlBase64 | base64 -d | kubectl apply -f -"
    return Invoke-AksCommand -Command $cmd -Description $Description
}

# Helper: base64-encode a plain string value for use in a Kubernetes Secret data field
function ConvertTo-SecretValue {
    param([string]$Value)
    return [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes($Value))
}

# ============================================================================
# Create RabbitMQ Secret
# ============================================================================

Write-Step "Creating RabbitMQ secret..."
$rabbitSecretName = "$RELEASE_NAME-rabbitmq-secret"
$rabbitYaml = @"
apiVersion: v1
kind: Secret
metadata:
  name: $rabbitSecretName
  namespace: $Namespace
type: Opaque
data:
  RABBITMQ_DEFAULT_USER: $(ConvertTo-SecretValue $RABBITMQ_USER)
  RABBITMQ_DEFAULT_PASS: $(ConvertTo-SecretValue $RABBITMQ_PASS)
"@

$result = Invoke-ApplySecretYaml -Yaml $rabbitYaml -Description "Create RabbitMQ secret ($rabbitSecretName)"
if (-not $result) {
    Write-Error-Message "Failed to create RabbitMQ secret"
    exit 1
}

# ============================================================================
# Create MongoDB Init Secret
# ============================================================================

Write-Step "Creating MongoDB init secret..."
$mongoSecretName = "$RELEASE_NAME-mongo-init-secret"
$mongoYaml = @"
apiVersion: v1
kind: Secret
metadata:
  name: $mongoSecretName
  namespace: $Namespace
type: Opaque
data:
  MONGO_INITDB_ROOT_USERNAME: $(ConvertTo-SecretValue $MONGO_ROOT_USERNAME)
  MONGO_INITDB_ROOT_PASSWORD: $(ConvertTo-SecretValue $MONGO_ROOT_PASSWORD)
"@

$result = Invoke-ApplySecretYaml -Yaml $mongoYaml -Description "Create MongoDB init secret ($mongoSecretName)"
if (-not $result) {
    Write-Error-Message "Failed to create MongoDB init secret"
    exit 1
}

# ============================================================================
# Create OpenSearch Admin Secret
# ============================================================================
# See kubectl-create-secrets.ps1 for full notes on OpenSearch password usage.
# OPENSEARCH_PASSWORD must match OPENSEARCH_INITIAL_ADMIN_PASSWORD here.
# ============================================================================

Write-Step "Creating OpenSearch admin secret..."
$opensearchSecretName = "$RELEASE_NAME-opensearch-admin-secret"
$opensearchYaml = @"
apiVersion: v1
kind: Secret
metadata:
  name: $opensearchSecretName
  namespace: $Namespace
type: Opaque
data:
  OPENSEARCH_INITIAL_ADMIN_PASSWORD: $(ConvertTo-SecretValue $OPENSEARCH_PASSWORD)
"@

$result = Invoke-ApplySecretYaml -Yaml $opensearchYaml -Description "Create OpenSearch admin secret ($opensearchSecretName)"
if (-not $result) {
    Write-Error-Message "Failed to create OpenSearch admin secret"
    exit 1
}

# ============================================================================
# Create Hybridsearch OI-RAG Secret
# ============================================================================

Write-Step "Creating Hybridsearch OI-RAG secret..."
$oiragSecretName = "$RELEASE_NAME-hybridsearch-oirag-secret"
$oiragYaml = @"
apiVersion: v1
kind: Secret
metadata:
  name: $oiragSecretName
  namespace: $Namespace
type: Opaque
data:
  OPENSEARCH_PASSWORD: $(ConvertTo-SecretValue $OPENSEARCH_PASSWORD)
  BEARER_TOKEN: $(ConvertTo-SecretValue $OIRAG_BEARER_TOKEN)
"@

$result = Invoke-ApplySecretYaml -Yaml $oiragYaml -Description "Create OI-RAG secret ($oiragSecretName)"
if (-not $result) {
    Write-Error-Message "Failed to create OI-RAG secret"
    exit 1
}

# ============================================================================
# Create Hybridsearch Remote Agent Secret
# ============================================================================

Write-Step "Creating Hybridsearch Remote Agent secret..."
$remoteAgentSecretName = "$RELEASE_NAME-hybridsearch-remoteagent-secret"
$remoteAgentYaml = @"
apiVersion: v1
kind: Secret
metadata:
  name: $remoteAgentSecretName
  namespace: $Namespace
type: Opaque
data:
  REMOTE_AGENT_TOKEN: $(ConvertTo-SecretValue $REMOTE_AGENT_TOKEN)
  SSL_CA_PASSWORD: $(ConvertTo-SecretValue $SSL_CA_PASSWORD)
"@

$result = Invoke-ApplySecretYaml -Yaml $remoteAgentYaml -Description "Create Remote Agent secret ($remoteAgentSecretName)"
if (-not $result) {
    Write-Error-Message "Failed to create Remote Agent secret"
    exit 1
}

# ============================================================================
# Create Admin Secret
# ============================================================================

Write-Step "Creating Admin secret..."
$MONGO_HOST = "$RELEASE_NAME-mongo"
$MONGODB_URI = "mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@${MONGO_HOST}:27017/${MONGO_DATABASE}?authSource=admin"
$adminSecretName = "$RELEASE_NAME-admin-secret"
$adminYaml = @"
apiVersion: v1
kind: Secret
metadata:
  name: $adminSecretName
  namespace: $Namespace
type: Opaque
data:
  MONGODB_URI: $(ConvertTo-SecretValue $MONGODB_URI)
  RABBITMQ_USERNAME: $(ConvertTo-SecretValue $RABBITMQ_USER)
  RABBITMQ_PASSWORD: $(ConvertTo-SecretValue $RABBITMQ_PASS)
  SCIM_USERNAME: $(ConvertTo-SecretValue $SCIM_USERNAME)
  SCIM_PASSWORD: $(ConvertTo-SecretValue $SCIM_PASSWORD)
"@

$result = Invoke-ApplySecretYaml -Yaml $adminYaml -Description "Create Admin secret ($adminSecretName)"
if (-not $result) {
    Write-Error-Message "Failed to create Admin secret"
    exit 1
}

# ============================================================================
# Create SCIM Secret
# ============================================================================

Write-Step "Creating SCIM secret..."
$SCIM_MONGO_URI = "mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@${MONGO_HOST}:27017/${MONGO_SCIM_DATABASE}?authSource=admin"
$scimSecretName = "$RELEASE_NAME-scim-secret"
$scimYaml = @"
apiVersion: v1
kind: Secret
metadata:
  name: $scimSecretName
  namespace: $Namespace
type: Opaque
data:
  SCIM_USERNAME: $(ConvertTo-SecretValue $SCIM_USERNAME)
  SCIM_PASSWORD: $(ConvertTo-SecretValue $SCIM_PASSWORD)
  SCIM_STORAGE_MONGO_CONSTR: $(ConvertTo-SecretValue $SCIM_MONGO_URI)
  SCIM_STORAGE_MONGO_DATABASE: $(ConvertTo-SecretValue $MONGO_SCIM_DATABASE)
"@

$result = Invoke-ApplySecretYaml -Yaml $scimYaml -Description "Create SCIM secret ($scimSecretName)"
if (-not $result) {
    Write-Error-Message "Failed to create SCIM secret"
    exit 1
}

# ============================================================================
# Create OAuth2 Secret
# ============================================================================
# Keeps Azure AD credentials out of the Helm release manifest (addresses H2).
# The Discovery service reads CLIENT_ID, TENANT_ID, CLIENT_SECRET, SCOPES
# directly from this secret via envFrom.secretRef.
# ============================================================================

Write-Step "Creating OAuth2 secret..."
$oauth2SecretName = "$RELEASE_NAME-oauth2-secret"
$oauth2Yaml = @"
apiVersion: v1
kind: Secret
metadata:
  name: $oauth2SecretName
  namespace: $Namespace
type: Opaque
data:
  CLIENT_ID: $(ConvertTo-SecretValue $OAUTH2_CLIENT_ID)
  TENANT_ID: $(ConvertTo-SecretValue $OAUTH2_TENANT_ID)
  CLIENT_SECRET: $(ConvertTo-SecretValue $OAUTH2_CLIENT_SECRET)
  SCOPES: $(ConvertTo-SecretValue $OAUTH2_SCOPES)
"@

$result = Invoke-ApplySecretYaml -Yaml $oauth2Yaml -Description "Create OAuth2 secret ($oauth2SecretName)"
if (-not $result) {
    Write-Error-Message "Failed to create OAuth2 secret"
    exit 1
}

# ============================================================================
# Verify Secrets
# ============================================================================

Write-Step "Verifying created secrets..."
$result = Invoke-AksCommand `
    -Command "kubectl get secrets -n $Namespace" `
    -Description "List secrets in namespace"

Write-Host "`n========================================" -ForegroundColor $SuccessColor
Write-Host "✓ Secrets created (except TLS - see manual steps above)" -ForegroundColor $SuccessColor
Write-Host "========================================`n" -ForegroundColor $SuccessColor

Write-Host "Next steps:" -ForegroundColor $InfoColor
Write-Host "1. Create TLS secret using Method 1 or 2 above" -ForegroundColor White
Write-Host "2. Update values-production.yaml with Azure AD OAuth2 credentials" -ForegroundColor White
Write-Host "3. Run: helm dependency update" -ForegroundColor White
Write-Host "4. Run: helm install threesixty-stack . -n $Namespace -f values-production.yaml" -ForegroundColor White
Write-Host ""

Write-Host "Note: The TLS certificate is self-signed (for development)." -ForegroundColor Yellow
Write-Host "For production, replace with a CA-signed certificate." -ForegroundColor Yellow
Write-Host ""

} finally {
    # Always delete the temp file — runs even if the script errors or is interrupted
    if (Test-Path $tempYamlPath) {
        Remove-Item $tempYamlPath -Force -ErrorAction SilentlyContinue
    }
}
