#!/usr/bin/env pwsh
# ============================================================================
# kubectl-create-secrets.ps1
# ============================================================================
# Creates Kubernetes secrets for 3Sixty deployment using kubectl commands
# 
# Prerequisites:
# - Azure CLI installed and authenticated (az login)
# - kubectl configured for your AKS cluster:
#   az aks get-credentials --resource-group <rg> --name <cluster-name>
# - AWS CLI configured (for ECR access)
# - OpenSSL installed (for certificate generation)
# 
# Usage:
#   .\kubectl-create-secrets.ps1
# ============================================================================

# Configuration from values-production.yaml
$NAMESPACE = "threesixty"
$ECR_SERVER = "782396859527.dkr.ecr.ap-southeast-2.amazonaws.com"
$ECR_REGION = "ap-southeast-2"
$DOMAIN = "threesixty.objective.com"
$RELEASE_NAME = "threesixty-stack"  # Must match your helm install release name

# ============================================================================
# Credential Variables - SET THESE BEFORE RUNNING
# ============================================================================
$MONGO_ROOT_USERNAME    = "dbuser"   # MongoDB root username
$MONGO_ROOT_PASSWORD    = ""   # MongoDB root password

$RABBITMQ_USER          = ""   # RabbitMQ username
$RABBITMQ_PASS          = ""   # RabbitMQ password

$OPENSEARCH_PASSWORD    = ""   # OpenSearch admin password (used by both OpenSearch pod and oirag)
$OIRAG_BEARER_TOKEN     = ""   # OI-RAG bearer token

$REMOTE_AGENT_TOKEN     = ""   # Remote agent token
$SSL_CA_PASSWORD        = ""   # SSL CA keystore password

# Colors for output
$SuccessColor = "Green"
$ErrorColor = "Red"
$InfoColor = "Cyan"

# ============================================================================
# Helper Functions
# ============================================================================

function Write-Step {
    param([string]$Message)
    Write-Host "`n[STEP] $Message" -ForegroundColor $InfoColor
}

function Write-Success {
    param([string]$Message)
    Write-Host "[OK] $Message" -ForegroundColor $SuccessColor
}

function Write-Error-Message {
    param([string]$Message)
    Write-Host "[ERROR] $Message" -ForegroundColor $ErrorColor
}

# ============================================================================
# Pre-flight Checks
# ============================================================================

Write-Host "`n========================================" -ForegroundColor $InfoColor
Write-Host "3Sixty Kubernetes Secrets Setup (kubectl)" -ForegroundColor $InfoColor
Write-Host "========================================`n" -ForegroundColor $InfoColor

Write-Step "Checking prerequisites..."

# Check kubectl
if (-not (Get-Command kubectl -ErrorAction SilentlyContinue)) {
    Write-Error-Message "kubectl not found. Please install kubectl first."
    exit 1
}
Write-Success "kubectl found"

# Check AWS CLI
if (-not (Get-Command aws -ErrorAction SilentlyContinue)) {
    Write-Error-Message "AWS CLI not found. Please install AWS CLI for ECR access."
    exit 1
}
Write-Success "AWS CLI found"

# Check OpenSSL
if (-not (Get-Command openssl -ErrorAction SilentlyContinue)) {
    Write-Error-Message "OpenSSL not found. Please install OpenSSL for certificate generation."
    exit 1
}
Write-Success "OpenSSL found"

# Check kubectl connectivity
Write-Step "Checking kubectl connectivity..."
try {
    kubectl cluster-info | Out-Null
    Write-Success "kubectl connected to cluster"
} catch {
    Write-Error-Message "Cannot connect to Kubernetes cluster. Run: az aks get-credentials --resource-group <rg> --name <cluster>"
    exit 1
}

# ============================================================================
# Create Namespace
# ============================================================================

Write-Step "Creating namespace '$NAMESPACE'..."
$namespaceExists = kubectl get namespace $NAMESPACE -o json 2>$null
if ($LASTEXITCODE -eq 0) {
    Write-Success "Namespace '$NAMESPACE' already exists"
} else {
    kubectl create namespace $NAMESPACE
    if ($LASTEXITCODE -eq 0) {
        Write-Success "Namespace '$NAMESPACE' created"
    } else {
        Write-Error-Message "Failed to create namespace"
        exit 1
    }
}

# ============================================================================
# Create ECR Registry Secret
# ============================================================================

Write-Step "Creating ECR registry secret..."

# Get ECR password
Write-Host "Getting ECR login password..." -ForegroundColor $InfoColor
try {
    $ECR_PASSWORD = aws ecr get-login-password --region $ECR_REGION
    if (-not $ECR_PASSWORD) {
        throw "Empty password returned"
    }
    Write-Success "ECR password retrieved"
} catch {
    Write-Error-Message "Failed to get ECR password. Ensure AWS CLI is configured with valid credentials."
    exit 1
}

# Check if secret exists
$secretExists = kubectl get secret ecr-registry-secret -n $NAMESPACE -o json 2>$null
if ($LASTEXITCODE -eq 0) {
    Write-Host "Secret 'ecr-registry-secret' already exists. Deleting and recreating..." -ForegroundColor Yellow
    kubectl delete secret ecr-registry-secret -n $NAMESPACE
}

# Create secret
kubectl create secret docker-registry ecr-registry-secret `
    --docker-server=$ECR_SERVER `
    --docker-username=AWS `
    --docker-password=$ECR_PASSWORD `
    -n $NAMESPACE

if ($LASTEXITCODE -eq 0) {
    Write-Success "ECR registry secret created"
} else {
    Write-Error-Message "Failed to create ECR registry secret"
    exit 1
}

# ============================================================================
# Create TLS Certificate Secret
# ============================================================================

Write-Step "Creating TLS certificate for domain '$DOMAIN'..."

# Create certs directory if it doesn't exist
$certsDir = "certs"
if (-not (Test-Path $certsDir)) {
    New-Item -ItemType Directory -Path $certsDir | Out-Null
    Write-Success "Created certs directory"
}

$certPath = "$certsDir/tls.crt"
$keyPath = "$certsDir/tls.key"

# Generate self-signed certificate
Write-Host "Generating self-signed certificate (valid for 365 days)..." -ForegroundColor $InfoColor
openssl req -x509 -newkey rsa:2048 -days 365 `
    -nodes `
    -keyout $keyPath `
    -out $certPath `
    -subj "/CN=$DOMAIN" 2>$null

if ($LASTEXITCODE -eq 0) {
    Write-Success "Certificate generated: $certPath"
    Write-Success "Private key generated: $keyPath"
} else {
    Write-Error-Message "Failed to generate certificate"
    exit 1
}

# Check if TLS secret exists
$tlsSecretExists = kubectl get secret traefik-tls -n $NAMESPACE -o json 2>$null
if ($LASTEXITCODE -eq 0) {
    Write-Host "Secret 'traefik-tls' already exists. Deleting and recreating..." -ForegroundColor Yellow
    kubectl delete secret traefik-tls -n $NAMESPACE
}

# Create TLS secret
kubectl create secret tls traefik-tls `
    --cert=$certPath `
    --key=$keyPath `
    -n $NAMESPACE

if ($LASTEXITCODE -eq 0) {
    Write-Success "TLS secret created"
} else {
    Write-Error-Message "Failed to create TLS secret"
    exit 1
}

# ============================================================================
# Validate credential variables are set
# ============================================================================

Write-Step "Validating credential variables..."
$missingVars = @()
if (-not $MONGO_ROOT_USERNAME)  { $missingVars += "MONGO_ROOT_USERNAME" }
if (-not $MONGO_ROOT_PASSWORD)  { $missingVars += "MONGO_ROOT_PASSWORD" }
if (-not $RABBITMQ_USER)        { $missingVars += "RABBITMQ_USER" }
if (-not $RABBITMQ_PASS)        { $missingVars += "RABBITMQ_PASS" }
if (-not $OPENSEARCH_PASSWORD)  { $missingVars += "OPENSEARCH_PASSWORD" }
if (-not $OIRAG_BEARER_TOKEN)   { $missingVars += "OIRAG_BEARER_TOKEN" }
if (-not $REMOTE_AGENT_TOKEN)   { $missingVars += "REMOTE_AGENT_TOKEN" }
if (-not $SSL_CA_PASSWORD)      { $missingVars += "SSL_CA_PASSWORD" }

if ($missingVars.Count -gt 0) {
    Write-Error-Message "The following credential variables are empty. Set them at the top of this script before running:"
    $missingVars | ForEach-Object { Write-Host "  `$$_" -ForegroundColor Yellow }
    exit 1
}
Write-Success "All credential variables set"

# ============================================================================
# Create RabbitMQ Secret
# ============================================================================

Write-Step "Creating RabbitMQ secret..."
$rabbitSecretName = "$RELEASE_NAME-rabbitmq-secret"
kubectl delete secret $rabbitSecretName -n $NAMESPACE --ignore-not-found=true | Out-Null
kubectl create secret generic $rabbitSecretName `
    --from-literal=RABBITMQ_DEFAULT_USER=$RABBITMQ_USER `
    --from-literal=RABBITMQ_DEFAULT_PASS=$RABBITMQ_PASS `
    -n $NAMESPACE

if ($LASTEXITCODE -eq 0) {
    Write-Success "RabbitMQ secret created ($rabbitSecretName)"
} else {
    Write-Error-Message "Failed to create RabbitMQ secret"
    exit 1
}

# ============================================================================
# Create MongoDB Init Secret
# ============================================================================

Write-Step "Creating MongoDB init secret..."
$mongoSecretName = "$RELEASE_NAME-mongo-init-secret"
kubectl delete secret $mongoSecretName -n $NAMESPACE --ignore-not-found=true | Out-Null
kubectl create secret generic $mongoSecretName `
    --from-literal=MONGO_INITDB_ROOT_USERNAME=$MONGO_ROOT_USERNAME `
    --from-literal=MONGO_INITDB_ROOT_PASSWORD=$MONGO_ROOT_PASSWORD `
    -n $NAMESPACE

if ($LASTEXITCODE -eq 0) {
    Write-Success "MongoDB init secret created ($mongoSecretName)"
} else {
    Write-Error-Message "Failed to create MongoDB init secret"
    exit 1
}

# ============================================================================
# Create OpenSearch Admin Secret
# ============================================================================
# OPENSEARCH_INITIAL_ADMIN_PASSWORD: sets the 'admin' superuser password.
# - Works natively on OpenSearch >= 2.12 via the env var.
# - On 2.4.1 (current chart version) this secret is created ready for when
#   OpenSearch is upgraded. Until then, configure the password manually via
#   securityadmin.sh or the Security API.
# - This password MUST match OPENSEARCH_PASSWORD in the oirag secret below.
# - Username 'admin' is used when setting up index jobs and data sources
#   in the 3Sixty admin application.
# ============================================================================

Write-Step "Creating OpenSearch admin secret..."
$opensearchSecretName = "$RELEASE_NAME-opensearch-admin-secret"
kubectl delete secret $opensearchSecretName -n $NAMESPACE --ignore-not-found=true | Out-Null
kubectl create secret generic $opensearchSecretName `
    --from-literal=OPENSEARCH_INITIAL_ADMIN_PASSWORD=$OPENSEARCH_PASSWORD `
    -n $NAMESPACE

if ($LASTEXITCODE -eq 0) {
    Write-Success "OpenSearch admin secret created ($opensearchSecretName)"
} else {
    Write-Error-Message "Failed to create OpenSearch admin secret"
    exit 1
}

# ============================================================================
# Create Hybridsearch OI-RAG Secret
# ============================================================================

Write-Step "Creating Hybridsearch OI-RAG secret..."
$oiragSecretName = "$RELEASE_NAME-hybridsearch-oirag-secret"
kubectl delete secret $oiragSecretName -n $NAMESPACE --ignore-not-found=true | Out-Null
kubectl create secret generic $oiragSecretName `
    --from-literal=OPENSEARCH_PASSWORD=$OPENSEARCH_PASSWORD `
    --from-literal=BEARER_TOKEN=$OIRAG_BEARER_TOKEN `
    -n $NAMESPACE

if ($LASTEXITCODE -eq 0) {
    Write-Success "OI-RAG secret created ($oiragSecretName)"
} else {
    Write-Error-Message "Failed to create OI-RAG secret"
    exit 1
}

# ============================================================================
# Create Hybridsearch Remote Agent Secret
# ============================================================================

Write-Step "Creating Hybridsearch Remote Agent secret..."
$remoteAgentSecretName = "$RELEASE_NAME-hybridsearch-remoteagent-secret"
kubectl delete secret $remoteAgentSecretName -n $NAMESPACE --ignore-not-found=true | Out-Null
kubectl create secret generic $remoteAgentSecretName `
    --from-literal=REMOTE_AGENT_TOKEN=$REMOTE_AGENT_TOKEN `
    --from-literal=SSL_CA_PASSWORD=$SSL_CA_PASSWORD `
    -n $NAMESPACE

if ($LASTEXITCODE -eq 0) {
    Write-Success "Remote Agent secret created ($remoteAgentSecretName)"
} else {
    Write-Error-Message "Failed to create Remote Agent secret"
    exit 1
}

# ============================================================================
# Verify Secrets
# ============================================================================

Write-Step "Verifying all secrets..."
kubectl get secrets -n $NAMESPACE

Write-Host "`n========================================" -ForegroundColor $SuccessColor
Write-Host "✓ All secrets created successfully!" -ForegroundColor $SuccessColor
Write-Host "========================================`n" -ForegroundColor $SuccessColor

Write-Host "Next steps:" -ForegroundColor $InfoColor
Write-Host "1. Update values-production.yaml with Azure AD OAuth2 credentials" -ForegroundColor White
Write-Host "2. Run: helm dependency update" -ForegroundColor White
Write-Host "3. Run: helm install threesixty-stack . -n $NAMESPACE -f values-production.yaml" -ForegroundColor White
Write-Host ""

Write-Host "Note: The TLS certificate is self-signed (for development)." -ForegroundColor Yellow
Write-Host "For production, replace with a CA-signed certificate:" -ForegroundColor Yellow
Write-Host "  kubectl create secret tls traefik-tls --cert=/path/to/cert.crt --key=/path/to/cert.key -n $NAMESPACE" -ForegroundColor White
Write-Host ""
